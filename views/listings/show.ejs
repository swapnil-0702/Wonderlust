<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-6 offset-3 show-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
    
    <div class="card-body">
      <p class="card-text"><i><%= listing.owner.username %></i></p>
      <p class="card-text"><%= listing.description %></p>
      <p class="card-text">&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
      <p class="card-text"><%= listing.location %></p>
      <p class="card-text"><%= listing.country %></p>
    </div>
  </div>

  <br>
  <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
  <div class="btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3">Edit</a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark offset-4 del-btn">Delete</button>
    </form>
  </div>
  <% } %>

  <% if(currUser) { %>
  <div class="col-8 offset-3 mb-3">
    <hr>
    <h4>Leave a Review</h4>
    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

  <fieldset class="starability-slot">
  <legend>First rating:</legend>

  <!-- LEFTMOST = 1 STAR -->
  <input type="radio" id="rate1" name="review[rating]" value="1">
  <label for="rate1" title="Terrible"></label>

  <input type="radio" id="rate2" name="review[rating]" value="2">
  <label for="rate2" title="Not good"></label>

  <input type="radio" id="rate3" name="review[rating]" value="3">
  <label for="rate3" title="Average"></label>

  <input type="radio" id="rate4" name="review[rating]" value="4">
  <label for="rate4" title="Very good"></label>

  <!-- RIGHTMOST = 5 STARS -->
  <input type="radio" id="rate5" name="review[rating]" value="5">
  <label for="rate5" title="Amazing"></label>
</fieldset>



      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        <div class="invalid-feedback">Please add some review</div>
      </div>

      <button class="btn btn-outline-dark">Submit</button>
    </form>
  <% } %>
    <hr>
  <% if(listing.reviews.length > 0) { %>
    <p><b>⭐ Reviews</b></p>

    <div class="container">
      <div class="row">
        <% for (let review of listing.reviews) { %>
          <div class="col-md-6 mb-4">
            <div class="card">
              <div class="card-body p-4">
                <h5 class="card-title mb-3">
                  @<%= review.author.username %>
                </h5>
                  <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                  <p class="card-text mb-3"><%= review.comment %></p>
                
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-outline-dark btn-sm">Delete</button>
                </form>
              </div>
            </div>
          </div>
        <% } %>
      </div>
      <hr class="mt-4">
      <% } %>
    </div>


<div class="row">
  <div class="col-lg-8 col-md-9 offset-lg-1 offset-md-1">
    <!-- Map heading -->
    <h3 class="mt-4 mb-3">Where you’ll be</h3>

    <!-- Map container -->
    <div id="map"></div>
  </div>
</div>

 <script>
  window.locationText = "<%= listing.location %>, <%= listing.country %>";
  window.listingTitle = "<%= listing.title %>";
</script>

<script src="/js/map.js"></script>
 
  </div>
</div>